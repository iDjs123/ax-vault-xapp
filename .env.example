# Xumm / Xaman SDK — get from developer.xumm.app
XUMM_API_KEY=your_xumm_api_key
XUMM_API_SECRET=your_xumm_api_secret
NEXT_PUBLIC_XUMM_API_KEY=your_xumm_api_key

# XRP destination wallet (your custody address)
XRP_DESTINATION=your_xrp_wallet_address

# Database (PostgreSQL — Supabase, PlanetScale, etc.)
DATABASE_URL="postgresql://user:pass@host:5432/db?pgbouncer=true"
DIRECT_URL="postgresql://user:pass@host:5432/db"

# Email notifications (Resend — resend.com)
RESEND_API_KEY=re_your_resend_api_key

# Base URL of your deployment
NEXT_PUBLIC_BASE_URL=https://yourdomain.com
